# All optional. ToolHunt works with zero configuration using the npm registry
# and GitHub search. These keys unlock additional sources / higher rate limits.

# Raises GitHub Search API rate limit from ~10/min to 5000/hour.
GITHUB_TOKEN=

# Enables the Smithery MCP registry as a source.
SMITHERY_API_KEY=

# Enables live web search via Tavily for discovering newer tools.
TAVILY_API_KEY=
